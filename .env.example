# ─────────────────────────────────────────────────────────────
#  Chatarr configuration — copy this file to ".env" and fill in.
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Branding ──────────────────────────────────────────────────
# The name shown on the web page and in the page title.
APP_NAME=Chatarr

# Which frontend(s) to run:  web  |  telegram  |  web,telegram
FRONTENDS=web

# Require admin approval before non-admin requests are added?
# When true, web/family requests are queued and you (the admin) get a Telegram
# message with Approve / Deny buttons; your own Telegram requests skip the queue.
# Needs the Telegram side configured (TELEGRAM_TOKEN + ADMIN_ID) for the notification.
REQUIRE_APPROVAL=false

# ── LLM — Groq (free tier works fine) ─────────────────────────
# Create a key at https://console.groq.com
GROQ_API_KEY=

# ── TMDB — discovery metadata ─────────────────────────────────
# "API Read Access Token" (v4) from https://www.themoviedb.org/settings/api
TMDB_TOKEN=

# ── Sonarr (TV) + Radarr (movies) ─────────────────────────────
# Point these at your existing Sonarr/Radarr. API keys: Settings → General.
# Both are required. URLs can be a LAN IP, hostname, or docker service name.
SONARR_URL=http://sonarr:8989
SONARR_KEY=
RADARR_URL=http://radarr:7878
RADARR_KEY=

# ── Web frontend  (used when FRONTENDS includes "web") ────────
# Leave WEB_PASSWORD blank for an OPEN page — only do that on a trusted LAN
# or behind an authenticated tunnel. Set it to require an access code.
WEB_PASSWORD=
WEB_PORT=8080

# ── Telegram frontend  (used when FRONTENDS includes "telegram") ──
# Bot token from @BotFather:
TELEGRAM_TOKEN=
# Your numeric Telegram user id (message @userinfobot to get it).
# Becomes the admin + first allowed user. Only needed for the Telegram frontend.
ADMIN_ID=
